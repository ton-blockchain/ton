const x1 = 0xFF;
const x2 = 0xAbcdEF01234561AC___;
const x3 = 0x00BEC;
const x4 = -0x_D7_0B;

const d1 = 255;
const d2 = 12_379_813_738_877_116_844;
const d3 = 003052;
const d4 = -55____051___;

const b1 = 0b_1111_1111;
const b2 = 0b_1010_1011_____11001101111011110000000100100011010001010110000110101100___;
const b3 = 0b00101111101100;
const b4 = -0b1101011100001011;

fun main() {
    assert(x1 == d1 && x1 == b1, 100);
    assert(x2 == d2 && x2 == b2, 100);
    assert(x3 == d3 && x3 == b3, 100);
    assert(x4 == d4 && x4 == b4, 100);
    assert(x1 + x2 + x3 == b1 + b2 + b3, 100);
    assert(-x2 == -d2 && -x2 == -b2, 100);

    return (
        0b1010101010101010+0b_00 == 43_690,
        0b0 == 0,
        -0b__1010100001010101010-0b1+0b1 == -344_746,
        0b00001 == 1__,
        -(-0b00101111101100) == 3052
    );
}

/**
@testcase | 0 |     | -1 -1 -1 -1 -1
 */
